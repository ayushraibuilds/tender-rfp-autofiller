{
  "manifest_version": 3,
  "name": "TenderPilot Portal Filler",
  "version": "0.1.0",
  "description": "Generate and autofill buyer portal questionnaires from TenderPilot API",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["http://localhost:8787/*", "https://*/*", "http://*/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
