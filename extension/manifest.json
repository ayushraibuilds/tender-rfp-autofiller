{
  "manifest_version": 3,
  "name": "TenderPilot Portal Filler",
  "version": "0.1.0",
  "description": "Autofill buyer portal questionnaires from TenderPilot draft JSON",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
