# Backend server port
PORT=8787

# Frontend origin allowed by CORS
CORS_ORIGIN=http://localhost:5173

# Optional: use OpenAI embeddings for higher-quality retrieval.
# If omitted, server uses a local hash-based vector fallback.
OPENAI_API_KEY=

# Change this in production.
JWT_SECRET=dev-only-secret-change-me

# Optional in frontend if backend isn't at localhost:8787
# VITE_API_BASE_URL=http://localhost:8787
