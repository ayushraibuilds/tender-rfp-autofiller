# Backend server port
PORT=8787
NODE_ENV=development

# Frontend origin allowed by CORS
CORS_ORIGIN=http://localhost:5173

# Optional: use OpenAI embeddings for higher-quality retrieval.
# Default is local Ollama embeddings for privacy/cost.
# EMBEDDING_PROVIDER can be: ollama | openai | hash
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Used only when EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=

# Change this in production.
JWT_SECRET=dev-only-secret-change-me

# API request rate limit per 15-minute window
RATE_LIMIT_MAX=300

# Optional in frontend if backend isn't at localhost:8787
# VITE_API_BASE_URL=http://localhost:8787
