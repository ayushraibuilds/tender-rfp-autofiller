# Backend server port
PORT=8787
NODE_ENV=development

# Database provider: sqlite | supabase
DATABASE_PROVIDER=supabase
# Required when DATABASE_PROVIDER=supabase
SUPABASE_DB_URL=postgresql://postgres:9BoAF9kOAJRbzMzk@db.bqwkhdblvshkuwtqmudo.supabase.co:5432/postgres?sslmode=require

# Frontend origin(s) allowed by CORS (comma-separated)
CORS_ORIGIN=http://localhost:5173

# Embeddings provider: groq | ollama | openai | hash
EMBEDDING_PROVIDER=groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_EMBEDDING_MODEL=text-embedding-3-small

# Optional local embeddings
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Used only when EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=

# Change this in production.
JWT_SECRET=dev-only-secret-change-me

# API request rate limit per 15-minute window
RATE_LIMIT_MAX=300

# Optional in frontend if backend isn't at localhost:8787
# VITE_API_BASE_URL=http://localhost:8787
